---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/results/`, label: 'Results' },
  { href: `${base}/setup/`, label: 'Setup' },
  { href: `${base}/agents/`, label: 'Agents' },
  { href: `${base}/stack/`, label: 'Stack' },
];

const currentPath = Astro.url.pathname;
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-container">
    <a class="nav-brand" href={base}>
      <span>Local LLM Guide</span>
    </a>
    <ul class="nav-links">
      {
        links.map((link) => {
          const isActive =
            currentPath === link.href || currentPath === link.href.replace(/\/$/, '');
          return (
            <li>
              <a href={link.href} aria-current={isActive ? 'page' : undefined}>
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</nav>
